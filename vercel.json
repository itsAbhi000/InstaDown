{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/fetch",    "dest": "/api/fetch.js"    },
    { "src": "/api/download", "dest": "/api/download.js" },
    { "src": "/(.*)",         "dest": "/public/$1"       }
  ]
}
